# Credentials for the Fellow live end-to-end test harness only
# (scripts/fellow-live-test.mts). The plugin itself reads the subdomain and key
# from its settings UI / data.json, NOT from the environment. Copy to .env and
# fill in; .env is gitignored.

# Workspace subdomain — the "acme" in acme.fellow.app. Not a secret.
FELLOW_SUBDOMAIN=acme

# Personal API key (User Settings -> Developer Tools). Secret — never commit.
FELLOW_API_KEY=
