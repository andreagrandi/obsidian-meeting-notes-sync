{
	"name": "obsidian-meeting-notes-sync",
	"version": "0.4.1",
	"description": "Sync meeting transcripts, notes, and AI summaries from MacParakeet and Fellow into your vault.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"release": "node scripts/release.mjs"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"meeting-notes",
		"macparakeet",
		"fellow"
	],
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^25.9.3",
		"esbuild": "0.28.1",
		"obsidian": "latest",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	}
}
