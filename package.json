{
	"name": "obsidian-macparakeet-sync",
	"version": "0.1.0",
	"description": "Unofficial Obsidian plugin that syncs MacParakeet meeting transcripts, notes, and AI summaries into your vault.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"macparakeet"
	],
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.15.17",
		"esbuild": "0.28.1",
		"obsidian": "latest",
		"typescript": "^5.8.3",
		"vitest": "^3.2.4"
	}
}
